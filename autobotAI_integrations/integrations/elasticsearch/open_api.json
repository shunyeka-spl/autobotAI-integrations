{
    "openapi": "3.0.0",
    "info": {
        "title": "Elasticsearch API",
        "version": "v8",
        "description": "An API for interacting with Elasticsearch, enabling users to search, index, and manage documents and indices in a distributed search and analytics engine.\n"
    },
    "servers": [
        {
            "url": "{base_url}",
            "description": "Elasticsearch instance URL",
            "variables": {
                "base_url": {
                    "default": "http://localhost:9200",
                    "description": "The base URL of your Elasticsearch instance."
                }
            }
        }
    ],
    "paths": {
        "/{index}/_search": {
            "get": {
                "summary": "Search Documents",
                "operationId": "searchDocuments",
                "description": "Execute a search query against an Elasticsearch index and retrieve matching documents. Supports full-text search, filtering, aggregations, and sorting.\n",
                "parameters": [
                    {
                        "name": "index",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "The name of the Elasticsearch index to search (e.g., \"my-logs\")."
                    },
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Lucene query string syntax for simple searches (e.g., \"status:active AND level:error\")."
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10,
                            "minimum": 1,
                            "maximum": 10000
                        },
                        "description": "Number of hits to return. Defaults to 10."
                    },
                    {
                        "name": "from",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 0
                        },
                        "description": "Starting document offset for pagination. Defaults to 0."
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Comma-separated list of field:order pairs to sort results (e.g., \"timestamp:desc\")."
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful search response containing matched documents.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "took": {
                                            "type": "integer",
                                            "description": "Time in milliseconds for Elasticsearch to execute the request."
                                        },
                                        "timed_out": {
                                            "type": "boolean",
                                            "description": "Whether the request timed out before completion."
                                        },
                                        "_shards": {
                                            "type": "object",
                                            "properties": {
                                                "total": {
                                                    "type": "integer",
                                                    "description": "Total number of shards queried."
                                                },
                                                "successful": {
                                                    "type": "integer",
                                                    "description": "Number of shards that responded successfully."
                                                },
                                                "skipped": {
                                                    "type": "integer",
                                                    "description": "Number of shards skipped."
                                                },
                                                "failed": {
                                                    "type": "integer",
                                                    "description": "Number of shards that failed."
                                                }
                                            }
                                        },
                                        "hits": {
                                            "type": "object",
                                            "properties": {
                                                "total": {
                                                    "type": "object",
                                                    "properties": {
                                                        "value": {
                                                            "type": "integer",
                                                            "description": "Total number of matching documents."
                                                        },
                                                        "relation": {
                                                            "type": "string",
                                                            "description": "Relation of the total hits count (e.g., \"eq\" or \"gte\")."
                                                        }
                                                    }
                                                },
                                                "max_score": {
                                                    "type": "number",
                                                    "nullable": true,
                                                    "description": "Highest relevance score among the returned hits."
                                                },
                                                "hits": {
                                                    "type": "array",
                                                    "description": "Array of matched documents.",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "_index": {
                                                                "type": "string",
                                                                "description": "The index the document belongs to."
                                                            },
                                                            "_id": {
                                                                "type": "string",
                                                                "description": "Unique document ID."
                                                            },
                                                            "_score": {
                                                                "type": "number",
                                                                "nullable": true,
                                                                "description": "Relevance score of the document."
                                                            },
                                                            "_source": {
                                                                "type": "object",
                                                                "description": "The original document body as indexed."
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request (e.g., invalid query syntax or parameters).",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized – invalid or missing API key.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Index not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "ApiKeyAuth": {
                "type": "apiKey",
                "in": "header",
                "name": "Authorization",
                "description": "Elasticsearch API key in the format: 'ApiKey <base64-encoded-id:api_key>'. Obtainable from your Elasticsearch cluster via the Create API Key API."
            }
        },
        "schemas": {
            "ErrorResponse": {
                "type": "object",
                "properties": {
                    "error": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string",
                                "description": "Error type (e.g., \"index_not_found_exception\")."
                            },
                            "reason": {
                                "type": "string",
                                "description": "Human-readable reason for the error."
                            },
                            "status": {
                                "type": "integer",
                                "description": "HTTP status code associated with the error."
                            }
                        }
                    },
                    "status": {
                        "type": "integer",
                        "description": "HTTP status code of the response."
                    }
                }
            }
        }
    },
    "security": [
        {
            "ApiKeyAuth": []
        }
    ]
}
