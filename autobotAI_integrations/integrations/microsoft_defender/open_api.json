                  "value": { "Query": "EmailEvents | where Timestamp > ago(7d) | where ThreatTypes has 'Phish' | project Timestamp, SenderFromAddress, RecipientEmailAddress, Subject, DeliveryAction, ThreatTypes | limit 100" }
                },
