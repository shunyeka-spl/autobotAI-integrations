                "QuarantinedEmails": {
                  "summary": "Find quarantined emails",
                  "value": { "Query": "EmailEvents | where DeliveryLocation == 'Quarantine' | where Timestamp > ago(24h) | project Timestamp, NetworkMessageId, SenderFromAddress, Subject | limit 100" }
                }
              }
            }
          }
