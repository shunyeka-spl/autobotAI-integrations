{
  "openapi": "3.0.3",
  "info": {
    "title": "Orca Security API",
    "description": "Orca Security agentless CNAPP REST API. Covers Alerts, Assets, Vulnerabilities, Compliance, and Asset Scanning across multi-cloud environments (AWS, Azure, GCP, Oracle Cloud, Alibaba Cloud).\n\n**Authentication:** `Authorization: Token <api_token>`\n\nGenerate your API token from the Orca dashboard: Settings → Users & Permissions → API → Add API Token. Assign at least the Viewer role for read-only access.\n\n**Base URL is region-specific:**\n- US: `https://app.orcasecurity.io`\n- EU: `https://app.eu.orcasecurity.io`\n- AU: `https://app.au.orcasecurity.io`\n- IN: `https://app.in.orcasecurity.io`\n- IL: `https://app.il.orcasecurity.io`",
    "version": "1.0.0",
    "contact": {
      "name": "Orca Security Docs",
      "url": "https://docs.orcasecurity.io"
    }
  },
  "servers": [
    {
      "url": "{base_url}",
      "description": "Orca Security tenant URL (region-specific)",
      "variables": {
        "base_url": {
          "default": "https://app.orcasecurity.io",
          "description": "Your Orca Security tenant base URL"
        }
      }
    }
  ],
  "security": [
    { "TokenAuth": [] }
  ],
  "components": {
    "securitySchemes": {
      "TokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API token in the format: `Token <your_api_token>`. Generated from Settings → Users & Permissions → API."
      }
    },
    "parameters": {
      "LimitParam": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "default": 20, "maximum": 10000 },
        "description": "Number of items to return per page. Default: 20, Maximum: 10000."
      },
      "OffsetParam": {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": { "type": "integer", "default": 0 },
        "description": "Number of items to skip for pagination."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "status": { "type": "integer" }
        }
      }
    }
  },
  "tags": [
    { "name": "Alerts", "description": "Query, update, and manage security alerts (risks, findings, misconfigurations)." },
    { "name": "Assets", "description": "Query cloud assets (VMs, containers, databases, functions, storage) and trigger scans." },
    { "name": "Vulnerabilities", "description": "Query CVE-based vulnerability findings across cloud workloads." },
    { "name": "Compliance", "description": "Query compliance framework status and coverage (CIS, SOC2, PCI-DSS, NIST, GDPR, HIPAA)." }
  ],
  "paths": {
    "/api/query/alerts": {
      "get": {
        "tags": ["Alerts"],
        "operationId": "listAlerts",
        "summary": "List Alerts",
        "description": "Retrieve a paginated list of security alerts from Orca Security. Supports filtering by severity, status, cloud account, and asset type. Alerts represent risks including vulnerabilities, misconfigurations, malware, IAM risks, and lateral movement.",
        "parameters": [
          { "$ref": "#/components/parameters/LimitParam" },
          { "$ref": "#/components/parameters/OffsetParam" },
          {
            "name": "severity",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["critical", "high", "medium", "low", "informational"]
            },
            "description": "Filter alerts by severity level."
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["open", "closed", "in_progress", "dismissed"]
            },
            "description": "Filter alerts by current status."
          },
          {
            "name": "cloud_account_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter alerts by cloud account ID."
          },
          {
            "name": "asset_type",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter alerts by asset type (e.g. virtual_machine, container, storage_bucket)."
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of alerts.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "type": "object" } },
                    "total_count": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "offset": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized — invalid or missing API token." },
          "403": { "description": "Forbidden — insufficient permissions." }
        }
      }
    },
    "/api/alerts/{alert_id}": {
      "get": {
        "tags": ["Alerts"],
        "operationId": "getAlert",
        "summary": "Get Alert by ID",
        "description": "Retrieve full details of a specific security alert by its unique ID, including risk context, affected asset, severity score, and remediation guidance.",
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The unique identifier of the alert."
          }
        ],
        "responses": {
          "200": {
            "description": "Alert object.",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Alert not found." }
        }
      },
      "put": {
        "tags": ["Alerts"],
        "operationId": "updateAlert",
        "summary": "Update Alert",
        "description": "Update the status or snooze state of a security alert. Use this to close alerts, mark them in progress, dismiss false positives, or snooze alerts for a defined number of days.",
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The unique identifier of the alert to update."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["open", "closed", "in_progress", "dismissed"],
                    "description": "New status for the alert."
                  },
                  "snooze": {
                    "type": "object",
                    "properties": {
                      "enabled": { "type": "boolean" },
                      "days": { "type": "integer", "description": "Number of days to snooze. Required when enabled is true." }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated alert object.",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "401": { "description": "Unauthorized." },
          "403": { "description": "Forbidden — token requires write permissions." },
          "404": { "description": "Alert not found." }
        }
      }
    },
    "/api/alerts/{alert_id}/comment": {
      "post": {
        "tags": ["Alerts"],
        "operationId": "addAlertComment",
        "summary": "Add Comment to Alert",
        "description": "Add a triage comment or note to a specific alert. Useful for documenting investigation findings, remediation steps, or escalation notes within Orca.",
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The unique identifier of the alert."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["comment"],
                "properties": {
                  "comment": {
                    "type": "string",
                    "description": "The comment text to add to the alert."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment added successfully.",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Alert not found." }
        }
      }
    },
    "/api/alerts/{alert_id}/verify": {
      "post": {
        "tags": ["Alerts"],
        "operationId": "verifyAlert",
        "summary": "Verify Alert",
        "description": "Initiate the verification process for a specific alert. This triggers Orca to re-validate the finding against the current state of the asset.",
        "parameters": [
          {
            "name": "alert_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The unique identifier of the alert to verify."
          }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": {
            "description": "Verification initiated.",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Alert not found." }
        }
      }
    },
    "/api/query/assets": {
      "get": {
        "tags": ["Assets"],
        "operationId": "listAssets",
        "summary": "List Assets",
        "description": "Retrieve a paginated list of cloud assets discovered by Orca Security across all connected cloud accounts. Supports filtering by asset type, cloud provider, and account.",
        "parameters": [
          { "$ref": "#/components/parameters/LimitParam" },
          { "$ref": "#/components/parameters/OffsetParam" },
          {
            "name": "asset_type",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by asset type (e.g. virtual_machine, container, storage_bucket, database, serverless_function, iam_user)."
          },
          {
            "name": "cloud_account_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter assets by cloud account ID."
          },
          {
            "name": "cloud_provider",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["aws", "azure", "gcp", "oci", "alibaba"]
            },
            "description": "Filter by cloud provider."
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of cloud assets.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "type": "object" } },
                    "total_count": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "offset": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." },
          "403": { "description": "Forbidden." }
        }
      }
    },
    "/api/assets/{asset_id}": {
      "get": {
        "tags": ["Assets"],
        "operationId": "getAsset",
        "summary": "Get Asset by ID",
        "description": "Retrieve full details of a specific cloud asset, including its configuration, associated alerts, vulnerability count, risk score, and metadata.",
        "parameters": [
          {
            "name": "asset_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The unique identifier of the asset."
          }
        ],
        "responses": {
          "200": {
            "description": "Asset object with full details.",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "401": { "description": "Unauthorized." },
          "404": { "description": "Asset not found." }
        }
      }
    },
    "/api/assets/{asset_id}/scan": {
      "post": {
        "tags": ["Assets"],
        "operationId": "scanAsset",
        "summary": "Trigger Asset Scan",
        "description": "Initiate an on-demand scan for a specific asset. This forces Orca to re-scan and re-evaluate the asset outside of the regular scan schedule. Note: this action runs asynchronously.",
        "parameters": [
          {
            "name": "asset_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The unique identifier of the asset to scan."
          }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": {
            "description": "Scan initiated successfully.",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "401": { "description": "Unauthorized." },
          "403": { "description": "Forbidden — token requires write permissions." },
          "404": { "description": "Asset not found." }
        }
      }
    },
    "/api/vulnerabilities": {
      "get": {
        "tags": ["Vulnerabilities"],
        "operationId": "listVulnerabilities",
        "summary": "List Vulnerabilities",
        "description": "Retrieve a paginated list of CVE-based vulnerability findings across all cloud workloads. Supports filtering by CVE ID, severity, asset, and cloud account.",
        "parameters": [
          { "$ref": "#/components/parameters/LimitParam" },
          { "$ref": "#/components/parameters/OffsetParam" },
          {
            "name": "cve_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by specific CVE identifier (e.g. CVE-2021-44228)."
          },
          {
            "name": "severity",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["critical", "high", "medium", "low", "informational"]
            },
            "description": "Filter vulnerabilities by severity level."
          },
          {
            "name": "asset_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter vulnerabilities for a specific asset."
          },
          {
            "name": "cloud_account_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter vulnerabilities by cloud account ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of vulnerability findings.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "type": "object" } },
                    "total_count": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "offset": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." },
          "403": { "description": "Forbidden." }
        }
      }
    },
    "/api/compliance": {
      "get": {
        "tags": ["Compliance"],
        "operationId": "getComplianceSummary",
        "summary": "Get Compliance Summary",
        "description": "Retrieve a summary of compliance framework status and coverage across all connected cloud accounts. Returns pass/fail statistics for each enabled framework (CIS, SOC2, PCI-DSS, NIST, GDPR, HIPAA, ISO27001, etc.).",
        "parameters": [
          {
            "name": "framework",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by specific compliance framework name (e.g. cis, soc2, pci_dss, nist, gdpr, hipaa)."
          },
          {
            "name": "cloud_account_id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter compliance data by cloud account ID."
          },
          { "$ref": "#/components/parameters/LimitParam" },
          { "$ref": "#/components/parameters/OffsetParam" }
        ],
        "responses": {
          "200": {
            "description": "Compliance framework summary.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "type": "object" } },
                    "total_count": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized." },
          "403": { "description": "Forbidden." }
        }
      }
    }
  }
}
